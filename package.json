{
  "name": "flow-batch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "青少年模式内容批量生成 BFF — 3 个接口通道（create-character / create-flow / gen-image）",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "pino": "^10.1.0",
    "pino-loki": "^2.6.0",
    "pino-pretty": "^13.1.2",
    "prom-client": "^15.1.3",
    "ulid": "^3.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
